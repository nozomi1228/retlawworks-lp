---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'RetlawWorks · Unlock the Best of Tokyo',
  description = 'Personal travel help for overseas visitors to Tokyo — food, hidden gems, local manners, and getting around. Plus custom Tokyo Disney planning. Just ask.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500;1,9..144,600&family=Inter:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <style>
    /* ── ローダーキーフレーム ── */
    @keyframes lineExpand {
      from { transform: scaleX(0); }
      to   { transform: scaleX(1); }
    }
    @keyframes lineFade {
      from { opacity: 1; }
      to   { opacity: 0.2; }
    }
    @keyframes logoIn {
      from { opacity: 0; transform: scale(0.94); }
      to   { opacity: 1; transform: scale(1); }
    }
    @keyframes logoOut {
      from { opacity: 1; transform: scale(1);    filter: blur(0px); }
      to   { opacity: 0; transform: scale(1.06); filter: blur(2px); }
    }
    @keyframes loaderHide {
      to { opacity: 0; }
    }
    /* reduced-motion 用シンプルフェード */
    @keyframes logoInSimple  { from { opacity: 0; } to { opacity: 1; } }
    @keyframes logoOutSimple { from { opacity: 1; } to { opacity: 0; } }

    #page-loader {
      position: fixed;
      inset: 0;
      z-index: 10000;
      background: #1A2A45;
      display: flex;
      align-items: center;
      justify-content: center;
      /* Phase 5: ローダー本体が 4.2s 後にフェードアウト */
      animation: loaderHide 0.55s 4.2s ease forwards;
    }
    .loader-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }
    .loader-line {
      width: 220px;
      height: 1px;
      background: #C9A66B;
      transform: scaleX(0);
      transform-origin: center;
      /*
        Phase 1: 0〜1.1s — 中央から左右に展開
        Phase 3: 1.4s〜 — ゴールド線がひっそり薄れる
      */
      animation:
        lineExpand 1.1s 0s    cubic-bezier(0.22, 1, 0.36, 1) forwards,
        lineFade   0.7s 1.4s  ease-out                        forwards;
    }
    .loader-logo {
      font-family: 'Fraunces', Georgia, serif;
      font-size: clamp(1.5rem, 4vw, 2.1rem);
      font-weight: 600;
      letter-spacing: 0.18em;
      color: #F4F1EA;
      opacity: 0;
      /*
        Phase 2: 0.9〜2.0s — 静かにフェードイン
        Phase 4: 2.9〜4.2s — ほんのり拡大しながら溶けるように消える
        ※ logoOut は logoIn より後ろに列挙 → CSSカスケードで自動的に上書き
      */
      animation:
        logoIn  1.1s 0.9s ease-out                      forwards,
        logoOut 1.3s 2.9s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }
    .loader-gold { color: #C9A66B; }

    /* prefers-reduced-motion: アニメーションを単純なフェードに簡略化 */
    @media (prefers-reduced-motion: reduce) {
      .loader-line {
        transform: scaleX(1);
        animation: lineFade 0.3s 0.6s ease-out forwards;
      }
      .loader-logo {
        animation:
          logoInSimple  0.3s 0.4s ease forwards,
          logoOutSimple 0.3s 1.4s ease forwards;
      }
      #page-loader {
        animation: loaderHide 0.3s 1.9s ease forwards;
      }
    }
  </style>
</head>
<body>
  <div id="page-loader">
    <div class="loader-inner">
      <div class="loader-line"></div>
      <div class="loader-logo">Retlaw<span class="loader-gold">Works</span></div>
    </div>
  </div>
  <slot />
</body>
</html>
